# ==================================================
# Delta Algo Trading Framework — Environment Template
# ==================================================
# Copy this file to .env and fill in real values:
#   cp .env.example .env
#
# NEVER commit .env to version control.
# ==================================================


# --------------------------------------------------
# API Credentials (Delta Exchange)
# --------------------------------------------------

# Your Delta Exchange API Key (required for live & paper trading)
DELTA_API_KEY=your_api_key_here

# Your Delta Exchange API Secret (required for live & paper trading)
DELTA_API_SECRET=your_api_secret_here

# Delta Exchange base REST API URL
# India:  https://api.india.delta.exchange
# Global: https://api.delta.exchange
DELTA_BASE_URL=https://api.india.delta.exchange


# --------------------------------------------------
# Trading Mode
# --------------------------------------------------

# One of: backtest | paper | live
TRADING_MODE=paper


# --------------------------------------------------
# Market Data
# --------------------------------------------------

# Candle resolution: 1m | 3m | 5m | 15m | 30m | 1h | 2h | 4h | 6h | 1d
CANDLE_RESOLUTION=1m

# Comma-separated list of symbols to track
SYMBOLS=BTCUSD


# --------------------------------------------------
# Risk Engine
# --------------------------------------------------

# Stop-loss calculation mode: absolute | percentage | atr
STOPLOSS_MODE=absolute

# Maximum allowable stop-loss distance (in price points for absolute mode)
MAX_STOPLOSS_DISTANCE=0.50

# Risk-to-reward ratio (e.g. 5.0 means 1:5 RR)
RISK_REWARD_RATIO=5.0


# --------------------------------------------------
# Backtesting
# --------------------------------------------------

# Trading fee rate (e.g. 0.001 = 0.1%)
TRADING_FEE_RATE=0.0

# Path to directory containing historical CSV files (relative to project root)
BACKTEST_DATA_DIR=data


# --------------------------------------------------
# WebSocket (reserved for future use)
# --------------------------------------------------

WS_URL=


# --------------------------------------------------
# Logging
# --------------------------------------------------

# Log level: DEBUG | INFO | WARNING | ERROR | CRITICAL
LOG_LEVEL=INFO


# --------------------------------------------------
# Dashboard
# --------------------------------------------------

# Port for the Streamlit dashboard (default: 8501)
DASHBOARD_PORT=8501


# --------------------------------------------------
# Deployment (systemd)
# --------------------------------------------------

# systemd service unit name — must match the .service filename
SERVICE_NAME=delta-algo

